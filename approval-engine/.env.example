# Ameen USR Database
AMEEN_USR=
AMEEN_PASS=
AMEEN_DSN=

# Fraud Database
FRAUD_USR=
FRAUD_PASS=
FRAUD_DSN=

# Connection Pool
AMEEN_POOL_MIN=2
AMEEN_POOL_MAX=10
FRAUD_POOL_MIN=2
FRAUD_POOL_MAX=10

# Scoring blender weights (must sum to 1.0)
RULE_WEIGHT=0.70
ML_WEIGHT=0.30

# Model artifact path
MODEL_PATH=artifacts/model_v1.pkl
SCALER_PATH=artifacts/scaler_v1.pkl

# HRSD Contract Verification API
# Called during scoring to verify contract details by contract_id.
# Set HRSD_MOCK_MODE=false and supply credentials when you have live API access.
# In mock mode, verification_score is randomised (0-100) per contract.
HRSD_MOCK_MODE=true
HRSD_API_URL=
HRSD_API_KEY=
HRSD_TIMEOUT_SECONDS=30

# MVP filters (Phase 1 scope)
TRANSACTION_ID_FILTER=101004
CHANNEL_FILTER=taminaty
LAWTYPE_FILTER=1001
HISTORY_START_DATE=01-03-2024
